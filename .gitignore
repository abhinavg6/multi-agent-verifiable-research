*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
*.tsbuildinfo

# Throwaway smoke / scratch
*-smoke.mjs
*-scratch.mjs
