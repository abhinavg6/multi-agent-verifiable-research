# --- Anthropic ---
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: Claude model. Defaults to a current Sonnet.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- MemWal (memory) ---
# Generate at https://memwal.ai (mainnet) or https://staging.memwal.ai (testnet).
# 1. Connect a Sui wallet, create a MemWalAccount, copy the account object ID below.
# 2. Generate a delegate key (Ed25519), copy the hex private key below.
# Memory ops have gas covered by the MemWal managed relayer — no SUI/WAL needed
# for the memory path itself.
MEMWAL_ACCOUNT_ID=
MEMWAL_DELEGATE_KEY=
MEMWAL_SERVER_URL=https://relayer.memwal.ai

# --- Sui keypair (FUNDS Walrus uploads) ---
# Bech32 Sui private key (`suiprivkey1…`). The address derived from this key:
#   - pays SUI gas for register + certify transactions on every blob
#   - holds the WAL coin balance the storage cost is charged from
#   - holds the SUI balance the upload-relay tip is charged from
# Aggregator GETs are anonymous — no keypair needed to fetch a blob.
#
# Funding (mainnet):
#   1. Buy WAL on any exchange that supports it, or buy SUI and swap to WAL.
#   2. Export the private key in bech32 form (suiprivkey1…) and paste below.
#   3. A small amount goes a long way: ~0.5 SUI + ~1 WAL covers many runs.
#
# Funding (testnet):
#   - SUI faucet: https://faucet.sui.io
#   - WAL: `walrus get-wal`
SUI_PRIVATE_KEY=
SUI_NETWORK=mainnet

# --- Walrus public-good endpoints ---
# Aggregator (read): anonymous HTTP, no keypair required
# Upload relay: encoding/sliver-distribution gateway, takes a SUI tip per upload
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
WALRUS_UPLOAD_RELAY_URL=https://upload-relay.mainnet.walrus.space
# Storage duration. ~14 days/epoch on mainnet, so 50 ≈ ~2 years.
WALRUS_EPOCHS=50
# Max upload-relay tip per blob in MIST (1 SUI = 1e9 MIST). 1e7 = 0.01 SUI.
WALRUS_UPLOAD_TIP_MAX_MIST=10000000

# --- Seal (optional snapshot encryption) ---
# When true, agent state snapshots are SEAL-encrypted before being pinned.
# Source bytes stay public — they came from public APIs; encrypting them
# would weaken the verifiable-citation story.
# Requires SEAL_PACKAGE_ID (a deployed seal_approve module) and reuses the
# SUI_PRIVATE_KEY above for the seal_approve transaction.
LAB_ENABLE_SEAL=false
SEAL_PACKAGE_ID=
SEAL_THRESHOLD=2

# --- Server ---
PORT=3040
